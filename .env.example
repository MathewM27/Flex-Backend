# ──────────────────────────────────────────────────────────────────────────────
# Flex backend — environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# Every variable listed here is read by `src/core/config.py` via pydantic-settings;
# missing required values abort startup.
# ──────────────────────────────────────────────────────────────────────────────

# Application
APP_ENV=local                          # local | staging | prod
APP_NAME=flex-backend
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR

# Database — async DSN, used by SQLAlchemy and Alembic
# When running inside docker-compose the host is `postgres`.
# When running pytest on the host against the compose DB, swap to `localhost`.
DATABASE_URL=postgresql+asyncpg://flex:flex@postgres:5432/flex

# Auth — JWT
# Generate locally: `python -c "import secrets; print(secrets.token_urlsafe(48))"`
JWT_SECRET=change-me-to-a-real-secret-min-32-chars-long
JWT_EXPIRES_MINUTES=1440               # 24h default per NFR-S2 / FR-A3

# CORS — comma-separated allowlist. No wildcard in prod (NFR-S4).
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Notifications
NOTIFICATION_PROVIDER=console          # console | twilio
TWILIO_ACCOUNT_SID=                    # required when NOTIFICATION_PROVIDER=twilio
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=                    # E.164, e.g. +15005550006 (Twilio sandbox)

# Payments
PAYMENT_PROVIDER=mock                  # mock (v1 only)
PAYMENT_WEBHOOK_SECRET=change-me-too   # HMAC secret for mock webhook signing

# Booking
BOOKING_PAYMENT_TIMEOUT_MINUTES=15     # PENDING_PAYMENT → EXPIRED window
